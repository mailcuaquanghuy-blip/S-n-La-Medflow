rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: username, password, fullName, role (ADMIN/STAFF), viewableDeptIds, editableDeptIds
    //
    // Collection: staff
    // Fields: name, role, deptId, avatar, capabilityIds, mainCapabilityIds, assistantCapabilityIds
    //
    // Collection: attendance
    // Fields: staffId, date, status
    //
    // Collection: patients
    // Fields: name, dob, gender, code, bedNumber, roomNumber, admissionDate, status, admittedByDeptId, referrals
    //
    // Collection: procedures
    // Fields: name, durationMinutes, deptId, etc.
    //
    // Collection: appointments
    // Fields: patientId, staffId, procedureId, deptId, date, startTime, endTime, status, etc.
    //
    // Collection: backups
    // Fields: deptId, backupDate, versionName, createdAt, snapshot, note, createdBy
    //
    // Collection: templates
    // Fields: name, procedureId, deptId, slots, etc.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated(); // For now, allow all authenticated users to act as admin
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validators
    
    function isValidUser(data) {
      return data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
             data.password is string && data.password.size() > 0 &&
             data.fullName is string && data.fullName.size() > 0 &&
             data.role in ['ADMIN', 'STAFF'];
    }

    function isValidStaff(data) {
      return data.name is string && data.name.size() > 0 &&
             data.role in ['Doctor', 'Technician', 'Nurse', 'PhysicianAssistant', 'Pharmacist'] &&
             data.deptId is string;
    }

    function isValidPatient(data) {
      return data.name is string && data.name.size() > 0 &&
             data.code is string && data.code.size() > 0 &&
             data.status in ['TREATING', 'DISCHARGED'];
    }

    function isValidAppointment(data) {
      return data.patientId is string &&
             data.staffId is string &&
             data.procedureId is string &&
             data.deptId is string &&
             data.status in ['PENDING', 'IN_PROGRESS', 'COMPLETED', 'CONFLICT'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /staff/{staffId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }

    match /attendance/{attendanceId} {
      allow read, create, update, delete: if isAuthenticated();
    }

    match /patients/{patientId} {
      allow read, create, update, delete: if isAuthenticated();
    }

    match /procedures/{procedureId} {
      allow read, create, update, delete: if isAuthenticated();
    }

    match /appointments/{appointmentId} {
      allow read, create, update, delete: if isAuthenticated();
    }

    match /backups/{backupId} {
      allow read, create, update, delete: if isAuthenticated();
    }
    
    match /machineShifts/{shiftId} {
      allow read, create, update, delete: if isAuthenticated();
    }

    match /templates/{templateId} {
      allow read, create, update, delete: if isAuthenticated();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
